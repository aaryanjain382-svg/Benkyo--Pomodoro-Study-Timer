# Turso (libSQL) connection — get these from `turso db show` / `turso db tokens create`
# or from the Turso dashboard. Set the same two values in Vercel under
# Project Settings -> Environment Variables.
TURSO_DATABASE_URL=libsql://your-db-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# For quick LOCAL testing without Turso you can instead point at a local file:
# TURSO_DATABASE_URL=file:dev.db
# (leave TURSO_AUTH_TOKEN unset in that case)
